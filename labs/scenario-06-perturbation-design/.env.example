# ---- Azure OpenAI (proposer + critic) ----
# Copy to .env and fill in. Leave blank to run the offline heuristic proposer.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# The *deployment name* you created in Azure OpenAI Studio (not the base model id)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ---- Optional: Azure AI Search (literature / prior-knowledge grounding) ----
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-key
AZURE_SEARCH_INDEX=perturbation-literature

# ---- Optional: Azure ML predictor endpoint (GEARS-style surrogate) ----
AZURE_ML_PREDICTOR_ENDPOINT=
AZURE_ML_PREDICTOR_KEY=
