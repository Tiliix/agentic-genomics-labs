# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values from your Azure resources.
# `.env` is git-ignored — NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Azure OpenAI resource endpoint, e.g. https://my-aoai.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://aoai-genomics-lab.openai.azure.com/

# The *deployment name* you gave your chat model (NOT the model name),
# e.g. "gpt-4o" or "gpt-4o-mini". Must support tool calling.
AZURE_OPENAI_DEPLOYMENT=gpt-5.1

# Azure OpenAI REST API version. 2024-06-01 or later supports tool calling.
AZURE_OPENAI_API_VERSION=2025-11-13

# Optional: connection string for the storage account used to stage
# FASTQs / counts / results. Leave blank to run fully local.
AZURE_STORAGE_CONNECTION_STRING=

