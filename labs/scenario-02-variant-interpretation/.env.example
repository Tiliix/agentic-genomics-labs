# ---------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit a real .env (it's in .gitignore).
# ---------------------------------------------------------------------------

# --- Azure OpenAI (required for src/agent.py) -------------------------------
# Resource endpoint, e.g. https://my-aoai-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
# The *deployment name* you created (NOT the base model name), e.g. gpt-4o
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# API version -- see Azure OpenAI docs for the current GA/preview value.
AZURE_OPENAI_API_VERSION=2024-10-21
# Auth option A: API key (simplest for a lab). Leave blank to use AAD instead.
AZURE_OPENAI_API_KEY=
# Auth option B: set to "true" to use azure-identity DefaultAzureCredential
# (keyless). Requires `az login` and the "Cognitive Services OpenAI User" role.
AZURE_OPENAI_USE_AAD=false

# --- Azure AI Search (OPTIONAL -- literature RAG citations) -----------------
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=variant-literature
AZURE_SEARCH_API_KEY=

# --- Annotation tuning (optional) -------------------------------------------
# MyVariant.info assembly: hg19 or hg38. The bundled example.vcf is hg38.
MYVARIANT_ASSEMBLY=hg38
# Be polite to public APIs: seconds between requests.
ANNOTATE_RATE_LIMIT_SECONDS=0.34
