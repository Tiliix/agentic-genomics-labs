# ---------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit a real .env (it's in .gitignore).
# ---------------------------------------------------------------------------

# --- Azure OpenAI (required for src/agent.py) -------------------------------
# Resource endpoint (resource ROOT). Classic data plane works with keyless auth:
#   https://YOUR-RESOURCE.openai.azure.com/   (or a services.ai.azure.com root)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
# The *deployment name* you created (NOT the base model name).
AZURE_OPENAI_DEPLOYMENT=gpt-5.1
# API version -- see Azure OpenAI docs for the current GA/preview value.
AZURE_OPENAI_API_VERSION=2024-10-21
# Auth: keyless Microsoft Entra ID is the DEFAULT -- run `az login` (your
# identity needs the "Cognitive Services OpenAI User" role) and leave the key
# line ABSENT. An empty AZURE_OPENAI_API_KEY= line breaks keyless auth, so keep
# it deleted. Only uncomment the next line to use key auth instead.
# AZURE_OPENAI_API_KEY=your-key-here

# --- Azure AI Search (OPTIONAL -- literature RAG citations) -----------------
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=variant-literature
AZURE_SEARCH_API_KEY=

# --- Annotation tuning (optional) -------------------------------------------
# MyVariant.info assembly: hg19 or hg38. The bundled example.vcf is hg38.
MYVARIANT_ASSEMBLY=hg38
# Be polite to public APIs: seconds between requests.
ANNOTATE_RATE_LIMIT_SECONDS=0.34
