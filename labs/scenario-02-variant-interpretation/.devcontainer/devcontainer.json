{
  "name": "Variant Interpretation Lab (Python 3.11)",
  // Microsoft-published Python 3.11 dev container base image.
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    // Azure CLI is handy for the infra/azure-setup.md steps.
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },
  // Install the lab's Python dependencies once the container is created.
  "postCreateCommand": "pip install --user -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-azureresourcegroups"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      }
    }
  },
  // Don't run as root inside the container.
  "remoteUser": "vscode"
}
