# ---------------------------------------------------------------------------
# Azure OpenAI (required for src/hypothesis_agent.py)
# ---------------------------------------------------------------------------
# Endpoint of your Azure OpenAI resource, e.g. https://my-aoai.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# API key. Leave blank to use azure-identity (DefaultAzureCredential / Managed Identity).
AZURE_OPENAI_API_KEY=
# The *deployment name* of your chat model (NOT the base model name), e.g. gpt-4o
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# API version
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---------------------------------------------------------------------------
# Azure AI Search (optional — evidence retrieval over a PubMed abstracts index)
# If unset, the agent falls back to the public PubMed E-utilities API.
# ---------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=pubmed-abstracts

# ---------------------------------------------------------------------------
# PubMed E-utilities (optional — improves rate limits / etiquette)
# ---------------------------------------------------------------------------
# NCBI recommends sending a tool name and contact email; an API key raises limits.
PUBMED_TOOL=multiomics-hypothesis-lab
PUBMED_EMAIL=
PUBMED_API_KEY=

# ---------------------------------------------------------------------------
# Lab behaviour
# ---------------------------------------------------------------------------
# Set to 1 to skip all network calls (no PubMed, no Search) for fully-offline runs.
OFFLINE=0
