# ---------------------------------------------------------------------------
# Azure OpenAI configuration for the cell-type annotation agent.
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
# `src/annotate_agent.py` loads these via python-dotenv.
# Do NOT commit your real .env (it is covered by .gitignore patterns).
# ---------------------------------------------------------------------------

# Base endpoint of your Azure OpenAI resource (no trailing path).
# Example: https://my-aoai-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/

# The *deployment name* you created for a chat model (e.g. gpt-4o, gpt-4o-mini).
# This is the deployment name, NOT the underlying model name.
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure OpenAI REST API version (data-plane). Bump as Azure releases newer ones.
AZURE_OPENAI_API_VERSION=2024-10-21

# ---------------------------------------------------------------------------
# Authentication — choose ONE of the two options below.
# ---------------------------------------------------------------------------

# Option A: API key auth (simplest for a lab). Leave blank to use Entra ID.
AZURE_OPENAI_API_KEY=

# Option B: Keyless auth via Microsoft Entra ID (DefaultAzureCredential).
# Set this to "true" to ignore the key above and use `az login` / managed identity.
# Requires the "Cognitive Services OpenAI User" role on the resource.
USE_AZURE_AD_AUTH=false
