{
  // VS Code Dev Container for the single-cell analysis training lab.
  // Opens in a reproducible Python 3.11 environment with all deps installed.
  "name": "scenario-03-single-cell",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",

  "features": {
    // Azure CLI is handy for the infra/azure-setup.md steps.
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },

  // Install Python dependencies after the container is created.
  // NOTE: requires internet on first build to pull the scientific stack.
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter",
        "ms-azuretools.vscode-azureresourcegroups"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  },

  // Forward nothing by default; clustering/plots are written to disk.
  "remoteUser": "vscode"
}
