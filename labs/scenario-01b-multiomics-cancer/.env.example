# ---------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit a real .env (it is in .gitignore).
# This lab is KEYLESS-FIRST: leave AZURE_OPENAI_API_KEY blank to use Azure AD
# (DefaultAzureCredential) -- just `az login` + the right role (see infra/).
# ---------------------------------------------------------------------------

# --- Azure OpenAI (required for src/agent.py) -------------------------------
# Resource endpoint, e.g. https://my-aoai-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/

# The *deployment name* you created (NOT the base model name), e.g. gpt-4o.
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API version -- see the Azure OpenAI docs for the current GA/preview value.
AZURE_OPENAI_API_VERSION=2024-10-21

# Auth: leave BLANK for keyless Azure AD (recommended). The agent uses an API key
# ONLY if this is non-empty. Keyless requires `az login` and the role assignment
# "Cognitive Services OpenAI User" (see infra/azure-setup.md).
AZURE_OPENAI_API_KEY=
