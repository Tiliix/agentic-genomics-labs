# Copy to .env and fill in. Do NOT commit your real .env.

# --- Azure OpenAI (required for src/rank_agent.py) ---
# Endpoint looks like: https://<your-resource>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
# The *deployment name* you created in the Azure portal (not the base model name).
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# API version that supports tool calling.
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Open Targets (public, no key needed) ---
OPENTARGETS_GRAPHQL_URL=https://api.platform.opentargets.org/api/v4/graphql

# --- Azure AI Search (optional literature-RAG extension) ---
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-admin-key
AZURE_SEARCH_INDEX=literature-rag
