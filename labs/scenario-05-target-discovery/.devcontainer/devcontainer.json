{
  // Python 3.11 devcontainer for the target-discovery lab.
  // Reopen the folder in this container from VS Code: "Dev Containers: Reopen in Container".
  "name": "target-discovery-lab",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  // Install Python deps once the container is created. Requires internet at build time.
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "GraphQL.vscode-graphql"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      }
    }
  },
  "remoteUser": "vscode"
}
